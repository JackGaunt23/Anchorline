{
  "name": "@anchorline/db",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "generate": "dotenv -e ../../.env -- prisma generate",
    "migrate:dev": "dotenv -e ../../.env -- prisma migrate dev",
    "migrate:deploy": "dotenv -e ../../.env -- prisma migrate deploy",
    "seed": "dotenv -e ../../.env -- tsx src/seed.ts",
    "typecheck": "tsc --noEmit",
    "build": "prisma generate"
  },
  "dependencies": {
    "@anchorline/providers": "workspace:*",
    "@prisma/client": "^6.10.1",
    "bcryptjs": "^3.0.2"
  },
  "devDependencies": {
    "@types/node": "^24.13.3",
    "dotenv-cli": "^8.0.0",
    "prisma": "^6.10.1",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3"
  }
}
