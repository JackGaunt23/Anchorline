# ============================================================
# Anchorline environment variables
# Copy to .env at the repo root and fill in.
# Demo mode (DATA_MODE=demo) needs only the CORE section.
# ============================================================

# ---- Core -------------------------------------------------
# Postgres connection string (docker-compose default shown)
DATABASE_URL=postgresql://anchorline:anchorline@localhost:5432/anchorline

# demo = deterministic sample data, zero external credentials
# live = RingCentral + AgencyZoom + Deepgram + OpenAI
DATA_MODE=demo

# Auth.js session secret — generate with: openssl rand -base64 32
AUTH_SECRET=change-me

# Owner login (single credentialed user, seeded by `pnpm db:seed`)
OWNER_EMAIL=owner@example.com
OWNER_PASSWORD=change-me
OWNER_NAME=Agency Owner

# Seeded agency row
AGENCY_NAME=Anchorline Insurance Group
AGENCY_TIMEZONE=America/New_York

# ---- RingCentral (live mode only, Phase 2) ----------------
# Private server-to-server app using the OAuth 2.0 JWT credentials flow.
# Requires ReadCallLog permission with admin-level auth.
RC_SERVER_URL=https://platform.ringcentral.com
RC_CLIENT_ID=
RC_CLIENT_SECRET=
RC_USER_JWT=

# How far back the FIRST live call sync reaches (days). Subsequent syncs
# resume from the previous successful run's watermark.
RC_SYNC_LOOKBACK_DAYS=90

# ---- AgencyZoom (live mode only, Phase 3) -----------------
# Direct login credentials for the agency owner user (API permissions equal
# the logged-in user's, so this must be the owner).
AZ_EMAIL=
AZ_PASSWORD=

# API server override (defaults to https://api.agencyzoom.com)
# AZ_BASE_URL=

# How far back the FIRST live CRM sync reaches (days). Subsequent syncs
# resume from the previous successful run's watermark.
AZ_SYNC_LOOKBACK_DAYS=365

# Max per-lead quote fetches per sync run. Quotes have no list endpoint, so
# each quoted lead costs one request against AgencyZoom's 30 req/min limit;
# large backfills drain across successive runs.
AZ_QUOTE_FETCH_BUDGET=200

# ---- AI pipeline (live mode only, Phase 4/5) --------------
# Transcription (Deepgram) — recorded calls only
DEEPGRAM_API_KEY=
# DEEPGRAM_MODEL=nova-3

# Call scoring and daily summaries (OpenAI Chat Completions API)
# API key from https://platform.openai.com
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.1
# API server override (default https://api.openai.com)
# OPENAI_BASE_URL=https://api.openai.com

# Minimum call duration (seconds) to enqueue transcription
MIN_TRANSCRIBE_SECONDS=120
