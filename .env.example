# ============================================================
# Anchorline environment variables
# Copy to .env at the repo root and fill in.
# Demo mode (DATA_MODE=demo) needs only the CORE section.
# ============================================================

# ---- Core -------------------------------------------------
# Postgres connection string (docker-compose default shown)
DATABASE_URL=postgresql://anchorline:anchorline@localhost:5432/anchorline

# demo = deterministic sample data, zero external credentials
# live = RingCentral + AgencyZoom + Deepgram + Anthropic
DATA_MODE=demo

# Auth.js session secret — generate with: openssl rand -base64 32
AUTH_SECRET=change-me

# Owner login (single credentialed user, seeded by `pnpm db:seed`)
OWNER_EMAIL=owner@example.com
OWNER_PASSWORD=change-me
OWNER_NAME=Agency Owner

# Seeded agency row
AGENCY_NAME=Anchorline Insurance Group
AGENCY_TIMEZONE=America/New_York

# ---- RingCentral (live mode only, Phase 2) ----------------
# Private server-to-server app using the OAuth 2.0 JWT credentials flow.
# Requires ReadCallLog permission with admin-level auth.
RC_SERVER_URL=https://platform.ringcentral.com
RC_CLIENT_ID=
RC_CLIENT_SECRET=
RC_USER_JWT=

# ---- AgencyZoom (live mode only, Phase 3) -----------------
# Direct login credentials for the agency owner user.
AZ_EMAIL=
AZ_PASSWORD=

# ---- AI pipeline (live mode only, Phase 4/5) --------------
DEEPGRAM_API_KEY=
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# Minimum call duration (seconds) to enqueue transcription
MIN_TRANSCRIBE_SECONDS=120
